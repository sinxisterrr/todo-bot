DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
# Optional: comma- or pipe-separated guild IDs for INSTANT deployment.
# Commands are always ALSO deployed globally (slow, up to 1hr) so the bot
# works in every server. Listing guilds here just makes updates instant
# for those specific ones. Leave blank for global-only.
# GUILD_ID=1234567890,9876543210
